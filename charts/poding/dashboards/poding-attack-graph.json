{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Critical Alert Status",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "No Active Alert"
                },
                "1": {
                  "color": "red",
                  "index": 1,
                  "text": "Active"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(poding_alert_active{scenario=~\"$scenario_filter\",severity=\"Critical\"}) or vector(0)",
          "legendFormat": "critical_alert_status",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Primary Suspect Pod",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-RdYlGr"
          },
          "unit": "dateTimeAsIso"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, poding_last_detection_timestamp_seconds{scenario=~\"$scenario_filter\"}) * 1000",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Infected / Risk Pod State",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 15,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (namespace,pod,state,severity) (poding_attack_node_state{namespace=~\"$target_namespaces\",scenario=~\"$scenario_filter\"})",
          "legendFormat": "{{namespace}}/{{pod}} [{{state}}/{{severity}}]",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "nodeGraph",
      "title": "Poding Correlation Node Graph",
      "description": "NodeGraph API datasource backed by propagation-exporter:9109. This graph uses Poding latest_correlation.json and latest_detection_summary.json, not raw Hubble flow. Nodes are pods colored by FSM/threat state; edges are detector correlation and propagation relations around the primary suspect and related pods.",
      "datasource": {
        "type": "hamedkarbasi93-nodegraphapi-datasource",
        "uid": "propagation-causal"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "targets": [
        {
          "queryType": "graph",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "FSM Progress by Pod",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (namespace,pod,scenario,state) (poding_fsm_progress_ratio{namespace=~\"$target_namespaces\",scenario=~\"$scenario_filter\"})",
          "legendFormat": "{{namespace}}/{{pod}} [{{state}}]",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Pod State Detail",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-RdYlGr"
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "poding_attack_node_state{namespace=~\"$target_namespaces\",scenario=~\"$scenario_filter\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "poding",
    "attack-graph",
    "propagation",
    "hubble",
    "falco"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {
          "selected": false,
          "text": ".*",
          "value": ".*"
        },
        "hide": 0,
        "label": "Scenario",
        "name": "scenario_filter",
        "options": [
          {
            "selected": true,
            "text": ".*",
