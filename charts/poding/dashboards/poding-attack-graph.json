          },
          {
            "selected": false,
            "text": "attack-lab-01_pod-a",
            "value": "attack-lab-01_pod-a"
          },
          {
            "selected": false,
            "text": "cluster-wide",
            "value": "cluster-wide"
          }
        ],
        "query": ".*",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": {
          "selected": false,
          "text": "attack-lab|poding-system|monitoring|kube-system|default",
          "value": "attack-lab|poding-system|monitoring|kube-system|default"
        },
        "hide": 0,
        "label": "Namespaces",
        "name": "target_namespaces",
        "options": [
          {
            "selected": true,
            "text": "attack-lab|poding-system|monitoring|kube-system|default",
            "value": "attack-lab|poding-system|monitoring|kube-system|default"
          },
          {
            "selected": false,
            "text": "attack-lab|poding-system",
            "value": "attack-lab|poding-system"
          }
        ],
        "query": "attack-lab|poding-system|monitoring|kube-system|default",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "",
  "title": "Pod-ing Attack Propagation",
  "uid": "poding-attack-graph",
  "version": 2
}
